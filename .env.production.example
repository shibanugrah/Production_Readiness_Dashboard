# Production environment template for a provider-neutral deployment.
# Copy these names into the chosen hosting provider's secret/configuration store.
# Never commit real production values.

NODE_ENV=production

# Required: managed PostgreSQL connection string for Prisma.
# Must not be a local, development, or placeholder database.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Required: unique high-entropy secrets, at least 32 characters each.
# Do not reuse local, test, or CI values.
AUTH_SECRET="replace-with-a-generated-production-secret"
INTERNAL_HEALTH_CHECK_SECRET="replace-with-a-generated-production-secret"

# Required: released image, commit, or build identifier.
# Must not be "local".
APP_VERSION="replace-with-release-version"

# Production safety: local/private target allowlists are development-only.
# Owner/Admin manual checks remain available and use persisted public service targets.
HEALTH_CHECK_LOCAL_ALLOWLIST_ENABLED=false
HEALTH_CHECK_LOCAL_ALLOWED_TARGETS=

# Production safety: controllable local demo health modes must not be exposed.
DEMO_SERVICE_HEALTH_ENABLED=false

# Public recruiter demo access is disabled by default.
PUBLIC_DEMO_ACCESS_ENABLED=false

# Required only when PUBLIC_DEMO_ACCESS_ENABLED=true.
# Use the deployed HTTPS app origin and a dedicated passwordless Viewer account.
# PUBLIC_DEMO_APP_BASE_URL=
# PUBLIC_DEMO_VIEWER_EMAIL=

# Optional one-time public-demo seed operator values.
# Configure these only while intentionally running `npm run db:seed` once.
# PUBLIC_DEMO_OWNER_EMAIL=
# PUBLIC_DEMO_OWNER_PASSWORD=

# Optional local demo seed values.
# Configure these only if the chosen deployment intentionally runs
# `npm run db:seed` once for the local-style demo workspace.
# DEMO_OWNER_EMAIL=
# DEMO_OWNER_PASSWORD=
# DEMO_ADMIN_EMAIL=
# DEMO_ADMIN_PASSWORD=
# DEMO_VIEWER_EMAIL=
# DEMO_VIEWER_PASSWORD=
