DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"
AUTH_SECRET="replace-with-a-generated-secret"
INTERNAL_HEALTH_CHECK_SECRET="replace-with-a-generated-secret"
NODE_ENV="development"
APP_VERSION="local"
HEALTH_CHECK_LOCAL_ALLOWLIST_ENABLED="true"
HEALTH_CHECK_LOCAL_ALLOWED_TARGETS="localhost:3000"
DEMO_OWNER_EMAIL="owner@example.local"
DEMO_OWNER_PASSWORD="replace-with-local-demo-owner-password"
DEMO_ADMIN_EMAIL="admin@example.local"
DEMO_ADMIN_PASSWORD="replace-with-local-demo-admin-password"
DEMO_VIEWER_EMAIL="viewer@example.local"
DEMO_VIEWER_PASSWORD="replace-with-local-demo-viewer-password"
