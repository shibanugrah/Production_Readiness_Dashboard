generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkspaceRole {
  OWNER
  ADMIN
  VIEWER
}

enum ServiceEnvironment {
  LOCAL
  PREVIEW
  STAGING
  PRODUCTION
}

enum ServiceStatus {
  UNKNOWN
  HEALTHY
  DEGRADED
  DOWN
}

enum HealthCheckStatus {
  SUCCESS
  DEGRADED
  FAILURE
}

enum HealthCheckRunTriggerType {
  MANUAL
  SCHEDULED
}

enum HealthCheckRunStatus {
  RUNNING
  COMPLETED
  FAILED
  SKIPPED
}

enum OperationalEventType {
  HEALTH_CHECK
  WEBHOOK
  JOB
  EXTRACTION
  DEPLOYMENT
  MIGRATION
}

enum OperationalEventSeverity {
  INFO
  WARNING
  ERROR
}

enum OperationalEventStatus {
  OPEN
}

model AppSetting {
  key       String   @id
  value     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Workspace {
  id                         String                      @id @default(cuid())
  name                       String
  slug                       String                      @unique
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt
  members                    WorkspaceMember[]
  services                   Service[]
  healthChecks               HealthCheck[]
  healthCheckRuns            HealthCheckRun[]
  healthCheckRunLease        HealthCheckRunLease?
  operationalEvents          OperationalEvent[]
  operationalEventIngestKeys OperationalEventIngestKey[]
  auditLogs                  AuditLog[]
}

model User {
  id                                String                      @id @default(cuid())
  name                              String
  email                             String                      @unique
  passwordHash                      String?
  createdAt                         DateTime                    @default(now())
  updatedAt                         DateTime                    @updatedAt
  memberships                       WorkspaceMember[]
  sessions                          Session[]
  auditLogs                         AuditLog[]
  requestedHealthCheckRuns          HealthCheckRun[]
  createdOperationalEventIngestKeys OperationalEventIngestKey[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(VIEWER)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

model Service {
  id                 String             @id @default(cuid())
  workspaceId        String
  name               String
  slug               String
  baseUrl            String
  healthPath         String
  environment        ServiceEnvironment
  expectedVersion    String?
  status             ServiceStatus      @default(UNKNOWN)
  isActive           Boolean            @default(true)
  lastCheckedAt      DateTime?
  lastHealthyAt      DateTime?
  checkLockToken     String?
  checkLockExpiresAt DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  workspace          Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  healthChecks       HealthCheck[]
  operationalEvents  OperationalEvent[]

  @@unique([workspaceId, slug])
  @@index([workspaceId, status])
  @@index([checkLockExpiresAt])
}

model HealthCheck {
  id               String            @id @default(cuid())
  requestId        String            @unique
  workspaceId      String
  serviceId        String
  runId            String?
  status           HealthCheckStatus
  httpStatus       Int?
  responseTimeMs   Int?
  observedVersion  String?
  migrationVersion String?
  message          String?
  checkedAt        DateTime          @default(now())
  createdAt        DateTime          @default(now())
  workspace        Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  service          Service           @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  run              HealthCheckRun?   @relation(fields: [runId], references: [id], onDelete: SetNull)

  @@index([workspaceId, serviceId, checkedAt])
  @@index([workspaceId, runId])
}

model HealthCheckRun {
  id                String                    @id @default(cuid())
  workspaceId       String
  triggerType       HealthCheckRunTriggerType
  status            HealthCheckRunStatus      @default(RUNNING)
  requestedByUserId String?
  startedAt         DateTime                  @default(now())
  finishedAt        DateTime?
  checkedCount      Int                       @default(0)
  healthyCount      Int                       @default(0)
  degradedCount     Int                       @default(0)
  downCount         Int                       @default(0)
  skippedCount      Int                       @default(0)
  errorCount        Int                       @default(0)
  errorMessage      String?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  workspace         Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  requestedByUser   User?                     @relation(fields: [requestedByUserId], references: [id], onDelete: SetNull)
  healthChecks      HealthCheck[]

  @@index([workspaceId, startedAt])
  @@index([workspaceId, triggerType, startedAt])
  @@index([workspaceId, status, startedAt])
  @@index([requestedByUserId])
}

model HealthCheckRunLease {
  workspaceId String    @id
  lockToken   String
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
}

model OperationalEvent {
  id                String                   @id @default(cuid())
  workspaceId       String
  serviceId         String?
  source            String                   @default("legacy")
  type              OperationalEventType
  severity          OperationalEventSeverity @default(INFO)
  status            OperationalEventStatus   @default(OPEN)
  message           String
  externalReference String?
  errorMessage      String?
  metadata          Json?
  payloadHash       String                   @default("legacy")
  idempotencyKey    String                   @default(cuid())
  occurredAt        DateTime                 @default(now())
  createdAt         DateTime                 @default(now())
  workspace         Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  service           Service?                 @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, source, idempotencyKey])
  @@index([workspaceId, occurredAt])
  @@index([workspaceId, status, severity, occurredAt])
  @@index([workspaceId, source, occurredAt])
}

model OperationalEventIngestKey {
  id              String    @id @default(cuid())
  workspaceId     String
  name            String
  source          String
  lookupId        String    @unique
  secretHash      String
  isActive        Boolean   @default(true)
  lastUsedAt      DateTime?
  revokedAt       DateTime?
  createdByUserId String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdByUser   User      @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([workspaceId, source, isActive])
  @@index([workspaceId, createdAt])
  @@index([createdByUserId])
}

model AuditLog {
  id           String    @id @default(cuid())
  workspaceId  String
  actorUserId  String
  action       String
  resourceType String
  resourceId   String
  metadataJson Json?
  createdAt    DateTime  @default(now())
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actorUser    User      @relation(fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([workspaceId, resourceType, resourceId, createdAt])
  @@index([actorUserId])
}
